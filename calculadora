<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <style>
        body {
            width: 1500px;
            height: 700px;
        }

        header {
            background: #22C1C3;
            background: linear-gradient(0deg, rgba(34, 193, 195, 1) 0%, rgba(253, 187, 45, 1) 100%);
            width: 100%;
            height: 10%;
        }

        h1 {
            color: rgb(5, 9, 236);
            font-family: arial;
            font-size: 100%;
            font-weight: bold;
            text-align: center;
        }

        h5 {
            color: rgb(24, 22, 22);
            font-family: arial;
            font-size: 60%;
            font-weight: bold;
            text-align: center;
        }

        main {
            background-color: rgb(23, 7, 255);
            width: 100%;
            height: 80%;
        }

        footer {
            background-color: rgba(233, 0, 12, 0.788);
            width: 100%;
            height: 10%;
        }


        .menu_principal {
            list-style-type: none;
            padding: 0;
            margin: 0;
            display: flex;
            gap: 20px;
        }

        .menu_principal>li {
            position: relative;
        }

        .menu_principal a {
            text-decoration: none;
            color: rgb(247, 0, 0);
            padding: 10px 15px;
            display: block;
        }

        .dropdown,
        .menu {
            display: none;
            /* Esconde os submenus */
            position: absolute;
            background-color: white;
            list-style-type: none;
            padding: 0;
            margin: 0;
            border: 1px solid #ccc;
            min-width: 150px;
            z-index: 1000;
        }

        .menu_principal>li:hover>.dropdown {
            display: block;
            /* Mostra o menu dropdown quando passa o mouse */
            top: 100%;
            left: 0;
        }

        .dropdown>li {
            position: relative;
        }

        .dropdown>li:hover>.menu {
            display: block;
            /* Mostra o submenu dentro do dropdown */
            top: 0;
            left: 100%;
        }

        .dropdown li,
        .menu li {
            padding: 10px;
            cursor: pointer;
        }

        /* Estilize quando o item está sendo hover */
        .dropdown li:hover,
        .menu li:hover {
            background-color: #f0f0f0;
        }
    </style>
</head>

<body>
